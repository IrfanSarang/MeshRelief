<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════════════
         Wi-Fi Direct (Issue #9)
         CHANGE_NETWORK_STATE is required by WifiP2pManager.connect()
         on API 29+. The others were already present.
         ════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />

    <!-- Internet for first-time map tile download -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Offline map storage -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Bluetooth fallback -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Background mesh service -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <application
        android:name=".MeshApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MeshRelief">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MeshRelief">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ══════════════════════════════════════════════════════════════
             Foreground Mesh Service (Issue #11)
             Keeps Wi-Fi Direct connections alive when the app is backgrounded.
             ══════════════════════════════════════════════════════════════ -->
        <service
            android:name=".service.MeshForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!--
        ══════════════════════════════════════════════════════════════════
        NOTE — WifiP2pBroadcastReceiver (Issue #9)
        ══════════════════════════════════════════════════════════════════
        The receiver is registered/unregistered PROGRAMMATICALLY in
        WifiDirectManager.initialize() / shutdown(), which are called
        from MainActivity.onResume / onPause (see Issue #9 wiring note).

        Do NOT register it statically here — WifiP2pManager intents are
        not delivered to static receivers on API 26+ (background limits).
        ══════════════════════════════════════════════════════════════════
        -->

    </application>

</manifest>